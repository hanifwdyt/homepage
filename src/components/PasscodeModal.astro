<!-- Passcode modal — triggered by data-protected-url attribute on cards -->
<dialog
  id="passcode-modal"
  class="fixed inset-0 z-50 m-0 h-full w-full max-h-none max-w-none bg-transparent p-0 backdrop:bg-black/60 backdrop:backdrop-blur-sm"
>
  <div class="flex h-full w-full items-center justify-center p-4">
    <div
      class="w-full max-w-sm rounded-2xl border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-neutral-950 p-6 shadow-2xl"
    >
      <div class="flex items-center gap-3 mb-5">
        <div
          class="size-9 rounded-lg bg-cyan-500/10 flex items-center justify-center text-cyan-500"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-neutral-900 dark:text-neutral-100">Personal app</h2>
          <p class="text-xs text-neutral-500 dark:text-neutral-400">Enter passcode to continue</p>
        </div>
        <button
          id="passcode-close"
          class="ml-auto text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200"
          aria-label="Close"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18M6 6l12 12" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <input
        id="passcode-input"
        type="password"
        inputmode="numeric"
        placeholder="Passcode"
        autocomplete="off"
        class="w-full px-3 py-2.5 text-sm rounded-lg border border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 placeholder:text-neutral-400 outline-none focus:border-cyan-500 transition-colors font-mono tracking-widest"
      />

      <p id="passcode-error" class="text-xs text-red-400 mt-2 hidden">Wrong passcode. Try again.</p>

      <button
        id="passcode-submit"
        class="mt-4 w-full py-2.5 text-sm font-medium rounded-lg bg-cyan-500 hover:bg-cyan-400 text-white transition-colors"
      >
        Continue →
      </button>

      <p class="text-[11px] text-neutral-400 dark:text-neutral-600 text-center mt-4">
        This is a personal app. Access is shared selectively.
      </p>
    </div>
  </div>
</dialog>

<script>
  // SHA-256 of "929283"
  const PASSCODE_HASH = "fa38398a1d6d1d9ab75bc793cb017e0055d83518067b0a16d6e04b0a01d2a44d";
  const SESSION_KEY = "hanif_unlocked";

  const modal = document.getElementById("passcode-modal") as HTMLDialogElement;
  const input = document.getElementById("passcode-input") as HTMLInputElement;
  const error = document.getElementById("passcode-error") as HTMLElement;
  const closeBtn = document.getElementById("passcode-close") as HTMLButtonElement;
  const submitBtn = document.getElementById("passcode-submit") as HTMLButtonElement;

  let pendingUrl = "";

  async function sha256(str: string): Promise<string> {
    const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, "0")).join("");
  }

  function openModal(url: string) {
    pendingUrl = url;
    input.value = "";
    error.classList.add("hidden");
    modal.showModal();
    setTimeout(() => input.focus(), 50);
  }

  function closeModal() {
    modal.close();
    pendingUrl = "";
    input.value = "";
    error.classList.add("hidden");
  }

  async function tryUnlock() {
    const hash = await sha256(input.value.trim());
    if (hash === PASSCODE_HASH) {
      sessionStorage.setItem(SESSION_KEY, "1");
      closeModal();
      window.open(pendingUrl, "_blank", "noopener,noreferrer");
    } else {
      error.classList.remove("hidden");
      input.value = "";
      input.focus();
    }
  }

  // Wire up events
  closeBtn.addEventListener("click", closeModal);
  submitBtn.addEventListener("click", tryUnlock);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter") tryUnlock();
    if (e.key === "Escape") closeModal();
  });
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });

  // Intercept all protected card clicks
  document.addEventListener("click", (e) => {
    const target = (e.target as HTMLElement).closest("[data-protected-url]");
    if (!target) return;
    e.preventDefault();
    const url = target.getAttribute("data-protected-url")!;
    // If already unlocked in this session, go directly
    if (sessionStorage.getItem(SESSION_KEY) === "1") {
      window.open(url, "_blank", "noopener,noreferrer");
    } else {
      openModal(url);
    }
  });
</script>
